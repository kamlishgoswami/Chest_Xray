# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
*.egg

# Virtual Environment
venv/
ENV/
env/
.venv

# Jupyter
.ipynb_checkpoints

# Models / weights (never commit)
*.h5
*.hdf5
*.keras
*.pb
*.pt
*.pth
*.onnx
saved_model/
checkpoints/

# Data (downloaded, not versioned)
data/raw/*
!data/raw/.gitkeep
data/masks/*
!data/masks/.gitkeep
data/processed/*
!data/processed/.gitkeep
# Drive-staging zips (8+ GB — never push to git; they live on Google Drive)
data/drive_staging/
# NOTE: data/manifest.csv (8 MB) IS intentionally tracked (Colab reuse + reproducibility)

# Copyrighted publisher PDFs — never commit (especially to a public repo)
Benchmark_papers/
*.pdf

# Old / legacy code, not for publication
legacy/
docs/_legacy/

# Results / outputs
results/*
!results/.gitkeep
*.log

# Paper build artifacts
paper/**/*.aux
paper/**/*.bbl
paper/**/*.blg
paper/**/*.out
paper/**/*.synctex.gz
paper/**/*.fls
paper/**/*.fdb_latexmk

# IDE / OS
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
